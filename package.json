{
  "name": "eve-corp-manager",
  "version": "1.0.0",
  "description": "EVE Online Corporation Management Dashboard — live ESI data",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "electron": "electron .",
    "rebuild": "electron-builder install-app-deps",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-session": "^1.17.0",
    "node-cron": "^3.0.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.toryngent.eve-corp-manager",
    "productName": "EVE Corp Manager",
    "copyright": "Copyright © 2026 Cray Rayner / Toryn Gent",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "public/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EVE Corp Manager",
      "uninstallDisplayName": "EVE Corp Manager"
    }
  }
}
