# EVE Online SSO credentials
# Register your app at https://developers.eveonline.com/applications
# Choose "Native Application" type — no client secret is needed or issued.
EVE_CLIENT_ID=your_eve_app_client_id_here

# Callback URL — must match exactly what you registered on the dev portal
EVE_CALLBACK_URL=http://localhost:3000/auth/callback

# Session secret — any long random string, keep it private
SESSION_SECRET=change_this_to_a_long_random_string

# App port (optional, defaults to 3000)
PORT=3000
