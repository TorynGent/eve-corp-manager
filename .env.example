# EVE Online SSO credentials
# Get these from https://developers.eveonline.com/applications
CLIENT_ID=your_eve_app_client_id_here
CLIENT_SECRET=your_eve_app_client_secret_here

# Session secret — use any long random string
SESSION_SECRET=change_this_to_a_long_random_string

# App port (optional, defaults to 3000)
PORT=3000
